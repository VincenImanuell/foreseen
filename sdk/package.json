{
  "name": "@foreseen/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Foreseen — the on-chain Rock Paper Scissors mind-sport on Celo. Matchmake, scout opponents from their on-chain history, commit-reveal, and build bots.",
  "license": "MIT",
  "author": "VincenImanuell",
  "homepage": "https://github.com/VincenImanuell/foreseen/tree/main/sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VincenImanuell/foreseen.git",
    "directory": "sdk"
  },
  "bugs": {
    "url": "https://github.com/VincenImanuell/foreseen/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./abi": {
      "types": "./dist/abi.d.ts",
      "import": "./dist/abi.js"
    },
    "./addresses": {
      "types": "./dist/addresses.d.ts",
      "import": "./dist/addresses.js"
    },
    "./chains": {
      "types": "./dist/chains.d.ts",
      "import": "./dist/chains.js"
    },
    "./crypto": {
      "types": "./dist/crypto.d.ts",
      "import": "./dist/crypto.js"
    },
    "./strategy": {
      "types": "./dist/strategy.d.ts",
      "import": "./dist/strategy.js"
    },
    "./scout": {
      "types": "./dist/scout.d.ts",
      "import": "./dist/scout.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./bot": {
      "types": "./dist/bot.d.ts",
      "import": "./dist/bot.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md",
    "llms.txt",
    "examples",
    "recipes"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "pack:dry-run": "npm pack --dry-run",
    "publish:check": "npm run typecheck && npm run test && npm run build && npm run pack:dry-run",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "viem": "^2.21.0",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "celo",
    "rock-paper-scissors",
    "web3",
    "game",
    "onchain-game",
    "web3-game",
    "ai-agent",
    "autonomous-agent",
    "rps-bot",
    "game-ai",
    "sdk",
    "typescript-sdk",
    "bot",
    "viem",
    "minipay",
    "commit-reveal"
  ]
}
