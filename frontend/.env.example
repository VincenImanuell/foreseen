# Foreseen frontend — all values are PUBLIC (safe to commit a copy as .env.local).
# No secrets, no API keys, no signups required.

# RPSCore on Celo Sepolia (already live & verified). Override only if you redeploy.
NEXT_PUBLIC_RPS_CORE_ADDRESS=0x208f098639059dF8E19a4F6836908b3cc56CdFf9

# Public Celo Sepolia RPC. The default works out of the box; override if you
# want to use your own endpoint.
NEXT_PUBLIC_CELO_SEPOLIA_RPC=https://forno.celo-sepolia.celo-testnet.org
