# Foreseen frontend — all values are PUBLIC (safe to commit a copy as .env.local).
# No secrets, no API keys, no signups required.

# RPSCore v2 on Celo mainnet (chain 42220, live). Override only if you redeploy.
NEXT_PUBLIC_RPS_CORE_ADDRESS=0x4DFc92FF97378D0F5E82d44EB968cb7793C5b90e

# RPSStats on Celo mainnet — read for opponent scouting.
NEXT_PUBLIC_RPS_STATS_ADDRESS=0x0f5F94A4f5C72CAc4D6E69a6DD89341c7b1a475A

# Public Celo mainnet RPC. The default works out of the box; override if you
# want to use your own endpoint.
NEXT_PUBLIC_CELO_RPC=https://forno.celo.org
