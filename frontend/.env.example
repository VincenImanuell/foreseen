# Foreseen frontend — all values are PUBLIC (safe to commit a copy as .env.local).
# No secrets, no API keys, no signups required.

# Network mode:
# - mainnet: live Celo deployment
# - sepolia: MiniPay Developer Settings -> Use Testnet
NEXT_PUBLIC_CELO_NETWORK=mainnet

# Public RPCs. Defaults work out of the box; override if you want your own endpoint.
NEXT_PUBLIC_CELO_RPC=https://forno.celo.org
NEXT_PUBLIC_CELO_SEPOLIA_RPC=https://forno.celo-sepolia.celo-testnet.org

# Optional contract overrides. Leave commented to use the built-in defaults for
# the selected network.
# NEXT_PUBLIC_RPS_CORE_ADDRESS=0x4DFc92FF97378D0F5E82d44EB968cb7793C5b90e
# NEXT_PUBLIC_RPS_STATS_ADDRESS=0x0f5F94A4f5C72CAc4D6E69a6DD89341c7b1a475A

# SovAds (https://sovads.org) — earns G$ per verified impression on the play
# page. Register a site at https://sovads.org/publisher to get a siteId; the
# banner stays disabled (renders nothing) until this is set.
# NEXT_PUBLIC_SOVADS_SITE_ID=site_YOUR_SITE_ID
